<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>14</LangVersion>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <!-- Embed git hash + dirty flag into AssemblyInformationalVersion (e.g. "26.2.0+9e92e46" or "26.2.0+9e92e46-dirty") -->
  <Target Name="SetGitHash" BeforeTargets="InitializeSourceControlInformation;CoreCompile">
    <Exec Command="git describe --always --dirty" ConsoleToMsBuild="true" StandardOutputImportance="low" IgnoreExitCode="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="SourceRevisionId" />
    </Exec>
    <!-- Write hash to a temp file so MSBuild detects changes and doesn't skip CoreCompile -->
    <WriteLinesToFile File="$(IntermediateOutputPath)git-hash.txt" Lines="$(SourceRevisionId)" Overwrite="true" WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <AdditionalCompileInputs Include="$(IntermediateOutputPath)git-hash.txt" />
      <CustomAdditionalCompileInputs Include="$(IntermediateOutputPath)git-hash.txt" />
    </ItemGroup>
  </Target>

  <PropertyGroup>
    <IncludeSourceRevisionInInformationalVersion>true</IncludeSourceRevisionInInformationalVersion>
    <Version>26.6.1</Version>
  </PropertyGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Assets\Images\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.3" />
    <PackageReference Include="Avalonia.Controls.DataGrid" Version="12.0.0" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.3" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.3" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.3" />
    <!-- NativeWebView (WebView2 on Windows / WKWebView mac / WPE Linux) for the
         all-in-one WebView launcher. -->
    <PackageReference Include="Avalonia.Controls.WebView" Version="12.0.1" />
    <PackageReference Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.0">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.0.0" />
    <!-- Phase 10 headless daemon: Type=notify readiness + journald formatting +
         SystemdLifetime (SIGTERM) when run under systemd; no-op otherwise. -->
    <PackageReference Include="Microsoft.Extensions.Hosting.Systemd" Version="9.0.0" />
    <!-- Windows counterpart: WindowsServiceLifetime (SCM start/stop) + EventLog
         logging when run as a Windows Service; no-op otherwise (incl. macOS/Linux). -->
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="9.0.0" />
    <PackageReference Include="StbImageSharp" Version="2.30.15" />
    <PackageReference Include="System.IO.Ports" Version="9.0.0" />
  </ItemGroup>

  <!-- The all-in-one launcher's NativeWebView uses Avalonia.Controls.WebView's WebView2 backend,
       which carries its own COM interop (Avalonia.Controls.Win.WebView2.Interop) and P/Invokes
       the native WebView2Loader.dll — but that package ships no native asset (its net10.0 dep
       group pulls only Avalonia), so the loader is absent from a win-x64/arm64 self-contained
       publish and the WebView renders blank. Reference Microsoft.Web.WebView2 on Windows RIDs to
       supply WebView2Loader.dll. IncludeAssets="native;runtime" takes ONLY the loader: the
       package's build targets otherwise hardcode WPF + WinForms managed flavor references (no
       opt-out) that are dead weight on our non-"-windows" net10.0 TFM and drag in a WindowsBase
       conflict (MSB3277). Windows-only — absent from the macOS/iOS/Linux/Android publishes. -->
  <ItemGroup Condition="$(RuntimeIdentifier.StartsWith('win'))">
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4022.49"
                      IncludeAssets="native;runtime" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\AgOpenWeb.Models\AgOpenWeb.Models.csproj" />
    <ProjectReference Include="..\..\Shared\AgOpenWeb.Services\AgOpenWeb.Services.csproj" />
    <ProjectReference Include="..\..\Shared\AgOpenWeb.ViewModels\AgOpenWeb.ViewModels.csproj" />
    <ProjectReference Include="..\..\Shared\AgOpenWeb.RemoteServer\AgOpenWeb.RemoteServer.csproj" />
    <ProjectReference Include="..\..\Shared\AgOpenWeb.RemoteWiring\AgOpenWeb.RemoteWiring.csproj" />
  </ItemGroup>

</Project>
