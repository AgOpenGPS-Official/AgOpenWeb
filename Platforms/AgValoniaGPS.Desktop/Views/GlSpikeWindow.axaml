<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:AgValoniaGPS.Views.Controls"
        x:Class="AgValoniaGPS.Desktop.Views.GlSpikeWindow"
        Title="GL Spike (Silk.NET + Avalonia OpenGlControlBase)"
        Width="1200" Height="800">
    <Grid RowDefinitions="* Auto">
        <c:GlSpikeControl Grid.Row="0" x:Name="Gl"/>
        <TextBlock Grid.Row="1" Margin="8" Foreground="LightGray"
                   Text="If you see a green ground plane, yellow boundary rectangle, and red cross at the center under tilted perspective — the GL path works. Esc to close."/>
    </Grid>
</Window>
