<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AgValoniaGPS.VehicleSimulator.ViewModels"
        x:Class="AgValoniaGPS.VehicleSimulator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AgValoniaGPS Vehicle Simulator"
        Width="750" Height="480"
        MinWidth="400" MinHeight="200">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Vehicle Simulator"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,12" />

        <!-- Main content: three columns, scrollable when window is too small -->
        <ScrollViewer Grid.Row="1" Margin="0,0,0,12"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="*,*,*">

            <!-- Column 1: Vehicle -->
            <Border Grid.Column="0" Margin="0,0,6,0" Padding="12"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4">
                <StackPanel Spacing="8">
                    <TextBlock Text="Vehicle" FontWeight="SemiBold" FontSize="14" />

                    <TextBlock Text="Drive Mode" />
                    <ComboBox SelectedItem="{Binding DriveMode}" HorizontalAlignment="Stretch">
                        <vm:DriveMode>Bicycle</vm:DriveMode>
                        <vm:DriveMode>Raw</vm:DriveMode>
                    </ComboBox>

                    <TextBlock Text="{Binding Speed, StringFormat='Speed: {0:F1} km/h'}" />
                    <Slider Minimum="0" Maximum="30" Value="{Binding Speed}"
                            TickFrequency="1" IsSnapToTickEnabled="False" />

                    <TextBlock Text="{Binding Heading, StringFormat='Heading: {0:F1} deg'}" />
                    <Slider Minimum="0" Maximum="359.9" Value="{Binding Heading}"
                            TickFrequency="1" IsSnapToTickEnabled="False" />

                    <TextBlock Text="{Binding Latitude, StringFormat='Latitude: {0:F6}'}" />
                    <NumericUpDown Value="{Binding Latitude}" Increment="0.0001"
                                   FormatString="F6" Minimum="-90" Maximum="90" />

                    <TextBlock Text="{Binding Longitude, StringFormat='Longitude: {0:F6}'}" />
                    <NumericUpDown Value="{Binding Longitude}" Increment="0.0001"
                                   FormatString="F6" Minimum="-180" Maximum="180" />
                </StackPanel>
            </Border>

            <!-- Column 2: Sensors -->
            <Border Grid.Column="1" Margin="3,0,3,0" Padding="12"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4">
                <StackPanel Spacing="8">
                    <TextBlock Text="Sensors" FontWeight="SemiBold" FontSize="14" />

                    <TextBlock Text="{Binding WasAngle, StringFormat='WAS Angle: {0:F1} deg'}" />
                    <Slider Minimum="-45" Maximum="45" Value="{Binding WasAngle}"
                            TickFrequency="1" IsSnapToTickEnabled="False" />

                    <TextBlock Text="{Binding RollAngle, StringFormat='Roll: {0:F1} deg'}" />
                    <Slider Minimum="-15" Maximum="15" Value="{Binding RollAngle}"
                            TickFrequency="0.5" IsSnapToTickEnabled="False" />

                    <TextBlock Text="{Binding FixQuality, StringFormat='GPS Fix Quality: {0}'}" />
                    <ComboBox SelectedIndex="{Binding FixQuality}" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="0 - No Fix" />
                        <ComboBoxItem Content="1 - GPS" />
                        <ComboBoxItem Content="2 - DGPS" />
                        <ComboBoxItem Content="3 - PPS" />
                        <ComboBoxItem Content="4 - RTK Fixed" />
                        <ComboBoxItem Content="5 - RTK Float" />
                    </ComboBox>

                    <TextBlock Text="{Binding SatelliteCount, StringFormat='Satellites: {0}'}" />
                    <NumericUpDown Value="{Binding SatelliteCount}" Increment="1"
                                   Minimum="0" Maximum="30" />

                    <CheckBox Content="Steer Switch ON" IsChecked="{Binding SteerSwitchOn}" />

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Panel Width="14" Height="14">
                            <Border CornerRadius="7" BorderBrush="Black" BorderThickness="1"
                                    Background="LimeGreen"
                                    IsVisible="{Binding AutoSteerEngaged}" />
                            <Border CornerRadius="7" BorderBrush="Black" BorderThickness="1"
                                    Background="DimGray"
                                    IsVisible="{Binding !AutoSteerEngaged}" />
                        </Panel>
                        <TextBlock Text="AutoSteer Engaged (from host)" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Column 3: Module Status -->
            <Border Grid.Column="2" Margin="6,0,0,0" Padding="12"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4">
                <StackPanel Spacing="8">
                    <TextBlock Text="Module Status" FontWeight="SemiBold" FontSize="14" />

                    <TextBlock Text="{Binding CommandedAngle, StringFormat='Commanded Angle: {0:F1} deg'}" />

                    <TextBlock Text="{Binding PwmDisplay, StringFormat='PWM: {0}'}" />

                    <TextBlock Text="{Binding SteerSwitchOn, StringFormat='Steer Switch: {0}'}" />

                    <Separator Margin="0,8" />

                    <TextBlock Text="UDP Ports" FontWeight="SemiBold" />
                    <TextBlock Text="GPS out: 127.0.0.1:9999" FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="Steer listen: 0.0.0.0:8888" FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="Machine listen: 0.0.0.0:8889" FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Command="{Binding StartStopCommand}"
                    Content="{Binding StartStopLabel}"
                    MinWidth="100" HorizontalContentAlignment="Center"
                    Padding="16,8" />

            <TextBlock Grid.Column="1" Text="{Binding StatusText, StringFormat='Status: {0}'}"
                       VerticalAlignment="Center" Margin="16,0,0,0" />
        </Grid>
    </Grid>
</Window>
