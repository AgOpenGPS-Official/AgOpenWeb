<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:steer="clr-namespace:AgOpenWeb.ViewModels.Wizards.SteerWizard;assembly=AgOpenWeb.ViewModels"
             x:Class="AgOpenWeb.Views.Controls.Wizards.SteerWizard.RollCalibrationStepView"
             x:DataType="steer:RollCalibrationStepViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   FontSize="16" TextWrapping="Wrap" LineHeight="22"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" Margin="0,0,0,24"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top" Spacing="14">
                <!-- Roll helper diagram -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="8" Padding="8" HorizontalAlignment="Center">
                    <Image Source="avares://AgOpenWeb.Views/Assets/Icons/ConD_RollHelper.png"
                           Width="200" Height="120"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                </Border>

                <!-- Analog roll gauge -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16" HorizontalAlignment="Center"
                        MinWidth="320">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <Canvas Width="280" Height="160" HorizontalAlignment="Center"
                                x:Name="GaugeCanvas"/>

                        <!-- Numeric readout below gauge -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding LiveRoll, StringFormat='{}{0:F2}'}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="deg" FontSize="16"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                        <TextBlock Text="(no live data)" FontSize="12" FontStyle="Italic"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding !HasLiveData}"/>
                    </StackPanel>
                </Border>

                <!-- Invert Roll toggle with icon (check this FIRST) -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        CornerRadius="8" Padding="16,12" HorizontalAlignment="Center" MinWidth="300">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0"
                               Source="avares://AgOpenWeb.Views/Assets/Icons/ConDa_InvertRoll.png"
                               Width="32" Height="32" Stretch="Uniform"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="Invert Roll" FontSize="16" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsRollInvert}"
                                      OnContent="ON" OffContent="OFF"/>
                    </Grid>
                </Border>

                <!-- Zero Roll button with icon -->
                <Button Height="48" MinWidth="200"
                        HorizontalAlignment="Center" CornerRadius="8" Cursor="Hand"
                        Command="{Binding ZeroRollCommand}"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Image Source="avares://AgOpenWeb.Views/Assets/Icons/ConDa_RollSetZero.png"
                               Width="28" Height="28" Stretch="Uniform"/>
                        <TextBlock Text="Zero Roll" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </StackPanel>
                </Button>

                <!-- Roll Zero offset display -->
                <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Center" MinWidth="250">
                    <TextBlock Text="Roll Zero Offset:" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding RollZero, StringFormat='{}{0:F2}'}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#C0392B" CornerRadius="8" Padding="12" Margin="0,16,0,0"
                IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationMessage}" FontSize="14" TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Border>
    </Grid>
</UserControl>
