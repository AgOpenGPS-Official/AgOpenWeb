<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:steer="clr-namespace:AgOpenWeb.ViewModels.Wizards.SteerWizard;assembly=AgOpenWeb.ViewModels"
             xmlns:conv="using:AgOpenWeb.Views.Converters"
             x:Class="AgOpenWeb.Views.Controls.Wizards.SteerWizard.AntennaSetupStepView"
             x:DataType="steer:AntennaSetupStepViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="16" TextWrapping="Wrap"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" Margin="0,0,0,12"/>

        <!-- Two columns: Left = Pivot + Height, Right = Lateral Offset -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" VerticalAlignment="Center">
            <!-- Left column: Pivot + Height with top-crop image -->
            <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,8,0">
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="4">
                    <Image Source="{Binding AntennaTopImageSource, Converter={x:Static conv:StringToImageConverter.Instance}}"
                           Stretch="Uniform" MaxHeight="180" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="10" Padding="12,8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Pivot Distance" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="Antenna to rear axle (+ = ahead)" FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding AntennaPivot, StringFormat='{}{0:F2}'}"
                                     FontSize="18" FontWeight="Bold" Width="100" TextAlignment="Center"
                                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                     BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                     BorderThickness="2" CornerRadius="8" Padding="6,4"/>
                            <TextBlock Text="m" FontSize="16" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="10" Padding="12,8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Antenna Height" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="Above ground level" FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding AntennaHeight, StringFormat='{}{0:F2}'}"
                                     FontSize="18" FontWeight="Bold" Width="100" TextAlignment="Center"
                                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                     BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                     BorderThickness="2" CornerRadius="8" Padding="6,4"/>
                            <TextBlock Text="m" FontSize="16" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right column: Lateral Offset with offset-crop image -->
            <StackPanel Grid.Column="1" Spacing="8" Margin="8,0,0,0">
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="4">
                    <Image Source="{Binding AntennaOffsetImageSource, Converter={x:Static conv:StringToImageConverter.Instance}}"
                           Stretch="Uniform" MaxHeight="180" HorizontalAlignment="Center"/>
                </Border>
                <!-- L/C/R buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <Button Command="{Binding SetLeftCommand}" Width="76" Height="60"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="8" Cursor="Hand" Padding="0" Classes.selected="{Binding IsLeft}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <Image Source="avares://AgOpenWeb.Views/Assets/Icons/AntennaLeftOffset.png"
                                   Width="32" Height="32" Stretch="Uniform"/>
                            <TextBlock Text="Left" FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SetCenterCommand}" Width="76" Height="60"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="8" Cursor="Hand" Padding="0" Classes.selected="{Binding IsCenter}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <Image Source="avares://AgOpenWeb.Views/Assets/Icons/AntennaNoOffset.png"
                                   Width="32" Height="32" Stretch="Uniform"/>
                            <TextBlock Text="Center" FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SetRightCommand}" Width="76" Height="60"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="8" Cursor="Hand" Padding="0" Classes.selected="{Binding IsRight}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <Image Source="avares://AgOpenWeb.Views/Assets/Icons/AntennaRightOffset.png"
                                   Width="32" Height="32" Stretch="Uniform"/>
                            <TextBlock Text="Right" FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <!-- Offset value -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="10" Padding="12,8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Lateral Offset" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="From centerline (+ = right)" FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding AntennaOffset, StringFormat='{}{0:F2}'}"
                                     FontSize="18" FontWeight="Bold" Width="100" TextAlignment="Center"
                                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                     BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                     BorderThickness="2" CornerRadius="8" Padding="6,4"/>
                            <TextBlock Text="m" FontSize="16" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Background="#C0392B" CornerRadius="8" Padding="12" Margin="0,16,0,0"
                IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationMessage}" FontSize="14" TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.selected">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        </Style>
        <Style Selector="Button.selected TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        </Style>
    </UserControl.Styles>
</UserControl>
