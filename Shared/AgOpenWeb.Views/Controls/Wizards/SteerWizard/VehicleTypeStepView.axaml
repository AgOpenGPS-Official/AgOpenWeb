<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:steer="clr-namespace:AgOpenWeb.ViewModels.Wizards.SteerWizard;assembly=AgOpenWeb.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="500"
             x:Class="AgOpenWeb.Views.Controls.Wizards.SteerWizard.VehicleTypeStepView"
             x:DataType="steer:VehicleTypeStepViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                   Margin="0,0,0,12"/>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   FontSize="16"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Margin="0,0,0,24"/>

        <!-- Options - horizontal layout with big icons -->
        <UniformGrid Grid.Row="2" Columns="3" VerticalAlignment="Center"
                     Margin="0,0,0,0">
            <!-- Tractor -->
            <Button Classes="option-button"
                    Command="{Binding SelectTractor}"
                    Classes.selected="{Binding IsTractorSelected}"
                    Margin="8">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="180" Height="180"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            CornerRadius="12"
                            HorizontalAlignment="Center">
                        <Image Source="avares://AgOpenWeb.Views/Assets/Icons/vehiclePageTractor.png"
                               Width="140" Height="140"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Tractor"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Front axle steering"
                               FontSize="14"
                               Classes="option-desc"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Harvester -->
            <Button Classes="option-button"
                    Command="{Binding SelectHarvester}"
                    Classes.selected="{Binding IsHarvesterSelected}"
                    Margin="8">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="180" Height="180"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            CornerRadius="12"
                            HorizontalAlignment="Center">
                        <Image Source="avares://AgOpenWeb.Views/Assets/Icons/vehiclePageHarvester.png"
                               Width="140" Height="140"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Harvester"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Rear axle steering"
                               FontSize="14"
                               Classes="option-desc"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Articulated 4WD -->
            <Button Classes="option-button"
                    Command="{Binding SelectFourWD}"
                    Classes.selected="{Binding IsFourWDSelected}"
                    Margin="8">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="180" Height="180"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            CornerRadius="12"
                            HorizontalAlignment="Center">
                        <Image Source="avares://AgOpenWeb.Views/Assets/Icons/vehiclePageArticulated.png"
                               Width="140" Height="140"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Articulated 4WD"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Center pivot steering"
                               FontSize="14"
                               Classes="option-desc"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <!-- Validation message -->
        <Border Grid.Row="3"
                Background="#C0392B"
                CornerRadius="8"
                Padding="12"
                Margin="0,16,0,0"
                IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.option-button">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.option-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>
        <Style Selector="Button.option-button.selected">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.option-button.selected TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="TextBlock.option-desc">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
        <Style Selector="Button.option-button.selected TextBlock.option-desc">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.option-button.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        </Style>
    </UserControl.Styles>
</UserControl>
