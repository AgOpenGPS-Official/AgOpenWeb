<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:steer="clr-namespace:AgOpenWeb.ViewModels.Wizards.SteerWizard;assembly=AgOpenWeb.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="550"
             x:Class="AgOpenWeb.Views.Controls.Wizards.SteerWizard.WasCalibrationStepView"
             x:DataType="steer:WasCalibrationStepViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                   Margin="0,0,0,12"/>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   FontSize="16"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Margin="0,0,0,24"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" Spacing="14">
            <!-- WAS angle display with text -->
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="12"
                    Padding="16"
                    HorizontalAlignment="Stretch">
                <StackPanel Spacing="8">
                    <!-- WAS: X.X deg label -->
                    <TextBlock HorizontalAlignment="Center" FontSize="14"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                        <Run Text="WAS: "/><Run Text="{Binding LiveSteerAngle, StringFormat='{}{0:F1}'}"/><Run Text=" deg"/>
                    </TextBlock>

                    <!-- Horizontal bar indicator -->
                    <Grid Height="32" Margin="8,0">
                        <!-- Labels -->
                        <TextBlock Text="Left" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Right" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="4" Height="12" Margin="32,0">
                        <Grid>
                            <!-- Center tick mark -->
                            <Border Width="2" Height="12"
                                    Background="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Angle indicator - positioned via RenderTransform -->
                            <Border Width="8" Height="18" CornerRadius="3"
                                    Background="{DynamicResource SystemControlHighlightAccentBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    x:Name="WasIndicator"/>
                        </Grid>
                    </Border>

                    <!-- Numeric readout -->
                    <TextBlock Text="{Binding LiveSteerAngle, StringFormat='{}{0:F1}'}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="No hardware connected"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding !HasLiveData}"/>
                </StackPanel>
            </Border>

            <!-- Instruction text -->
            <TextBlock Text="Steer Angle must be POSITIVE when turning to the RIGHT. If not, select Invert WAS."
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="8,0"/>

            <!-- Zero WAS button with icon -->
            <Button Command="{Binding ZeroWasCommand}"
                    HorizontalAlignment="Center"
                    Width="180" Height="48"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="8"
                    HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Image Source="avares://AgOpenWeb.Views/Assets/Icons/SteerZero.png"
                           Width="28" Height="28" Stretch="Uniform"/>
                    <TextBlock Text="Zero WAS" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
            </Button>

            <!-- Invert WAS with icon -->
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="8" Padding="16,12" HorizontalAlignment="Center" MinWidth="300">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Image Grid.Column="0"
                           Source="avares://AgOpenWeb.Views/Assets/Icons/ConSt_InvertWAS.png"
                           Width="32" Height="32" Stretch="Uniform"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Invert WAS" FontSize="16"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="Enable if steering reads backwards" FontSize="12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="2" IsChecked="{Binding InvertWas}"
                                  OnContent="ON" OffContent="OFF"/>
                </Grid>
            </Border>

            <!-- WAS Offset -->
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="12" Padding="24,16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="WAS Offset"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBox Text="{Binding WasOffset, StringFormat='{}{0:F0}'}"
                                 FontSize="20" FontWeight="Bold"
                                 Width="110"
                                 TextAlignment="Center"
                                 Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                 Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                 BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                 BorderThickness="2" CornerRadius="8"
                                 Padding="8,6"/>
                        <TextBlock Text="counts"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>

        <!-- Validation message -->
        <Border Grid.Row="3"
                Background="#C0392B"
                CornerRadius="8"
                Padding="12"
                Margin="0,16,0,0"
                IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
