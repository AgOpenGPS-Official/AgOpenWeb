Tool/implement configuration dialog (one half of the former monolithic
ConfigurationDialog). A chained sub-dialog of the Vehicle/Tool picker: opened
via "Configure Tool", Back returns to the picker, Close dismisses the chain.
Tabs: Tool/Implement (incl. Sections), U-Turn, Machine Control, Tram Lines.
Shares ConfigurationViewModel + ConfigInputOverlays with the Vehicle dialog.
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:AgOpenWeb.Views.Localization;assembly=AgOpenWeb.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AgOpenWeb.ViewModels;assembly=AgOpenWeb.ViewModels"
             xmlns:conv="clr-namespace:AgOpenWeb.Views.Converters;assembly=AgOpenWeb.Views"
             xmlns:controls="clr-namespace:AgOpenWeb.Views.Controls;assembly=AgOpenWeb.Views"
             xmlns:config="clr-namespace:AgOpenWeb.Views.Controls.Dialogs.Configuration;assembly=AgOpenWeb.Views"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="750"
             x:Class="AgOpenWeb.Views.Controls.Dialogs.ToolConfigDialog"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding State.UI.IsToolConfigDialogVisible}"
             IsHitTestVisible="{Binding State.UI.IsToolConfigDialogVisible}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AgOpenWeb.Views/Controls/Dialogs/Configuration/ConfigIcons.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Main TabControl styling for left icon strip -->
        <Style Selector="TabControl.MainConfigTabs">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabControl.MainConfigTabs > TabItem">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="MinHeight" Value="64"/>
        </Style>
        <Style Selector="TabControl.MainConfigTabs > TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        </Style>
        <Style Selector="TabControl.MainConfigTabs > TabItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Border Background="Transparent" PointerPressed="Backdrop_PointerPressed"/>

        <controls:DialogChrome Title="{loc:Localize ToolConfiguration}"
                BackCommand="{Binding NavBackCommand}"
                CloseCommand="{Binding NavCloseChainCommand}"
                MinWidth="900" MaxWidth="980" MinHeight="620" MaxHeight="820">
            <Grid RowDefinitions="*,Auto"
                  DataContext="{Binding ConfigurationViewModel}">
                <!-- Main content area with TabControl + shared input overlays -->
                <Panel Grid.Row="0">
                    <TabControl Classes="MainConfigTabs" TabStripPlacement="Left" Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <!-- Tool Tab -->
                        <TabItem ToolTip.Tip="Implement/Tool">
                            <TabItem.Header>
                                <Border Width="40" Height="40" Background="{DynamicResource IconTool}"/>
                            </TabItem.Header>
                            <config:ToolConfigTab/>
                        </TabItem>

                        <!-- U-Turn Tab -->
                        <TabItem ToolTip.Tip="U-Turn">
                            <TabItem.Header>
                                <Border Width="40" Height="40" Background="{DynamicResource IconUTurn}"/>
                            </TabItem.Header>
                            <config:UTurnConfigTab/>
                        </TabItem>

                        <!-- Machine Control Tab -->
                        <TabItem ToolTip.Tip="Machine Control">
                            <TabItem.Header>
                                <Border Width="40" Height="40" Background="{DynamicResource IconMachine}"/>
                            </TabItem.Header>
                            <config:MachineControlConfigTab/>
                        </TabItem>

                        <!-- Tram Lines Tab -->
                        <TabItem ToolTip.Tip="Tram Lines">
                            <TabItem.Header>
                                <Border Width="40" Height="40" Background="{DynamicResource IconTram}"/>
                            </TabItem.Header>
                            <config:TramConfigTab/>
                        </TabItem>
                    </TabControl>

                    <config:ConfigInputOverlays ZIndex="100"/>
                </Panel>

                <!-- Footer with tool profile info -->
                <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="16,12" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="{Binding Config.ActiveToolProfileName, StringFormat='Tool: {0}'}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontWeight="Bold" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{loc:Localize Width}" Foreground="{DynamicResource SystemControlForegroundBaseLowBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CalculatedTotalWidthText}"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </controls:DialogChrome>
    </Grid>
</UserControl>
