<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:steer="clr-namespace:AgValoniaGPS.ViewModels.Wizards.SteerWizard;assembly=AgValoniaGPS.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="550"
             x:Class="AgValoniaGPS.Views.Controls.Wizards.SteerWizard.SpeedAndSensorsStepView"
             x:DataType="steer:SpeedAndSensorsStepViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Title with skip indicator -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{Binding Title}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="4"
                    Padding="8,4"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    IsVisible="{Binding CanSkip}">
                <TextBlock Text="Optional"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </Border>
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   FontSize="16"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Margin="0,0,0,24"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!-- Min Steer Speed -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="24,16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Min Steer Speed"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Engage above this speed"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBox Text="{Binding MinSteerSpeed, StringFormat='{}{0:F1}'}"
                                     FontSize="20" FontWeight="Bold" Width="110"
                                     TextAlignment="Center"
                                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                     BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                     BorderThickness="2" CornerRadius="8"
                                     Padding="8,6"/>
                            <TextBlock Text="km/h"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Max Steer Speed -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="24,16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Max Steer Speed"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Safety cutoff speed"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBox Text="{Binding MaxSteerSpeed, StringFormat='{}{0:F1}'}"
                                     FontSize="20" FontWeight="Bold" Width="110"
                                     TextAlignment="Center"
                                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                     BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                     BorderThickness="2" CornerRadius="8"
                                     Padding="8,6"/>
                            <TextBlock Text="km/h"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Optional Sensors section -->
                <TextBlock Text="Optional Sensors"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           Margin="0,8,0,0"/>

                <!-- Turn Sensor -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="12" Padding="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Turn Sensor"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Steering wheel encoder"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding TurnSensorEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Pressure Sensor -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="12" Padding="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Pressure Sensor"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Hydraulic stall detection"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding PressureSensorEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Current Sensor -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="12" Padding="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Current Sensor"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Motor current obstruction detection"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding CurrentSensorEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Safety section -->
                <TextBlock Text="Safety"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           Margin="0,8,0,0"/>

                <!-- Steer In Reverse -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="12" Padding="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Steer In Reverse"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Allow steering while reversing"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SteerInReverse}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Deadzone Heading -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="24,16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Deadzone Heading"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Heading error tolerance"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBox Text="{Binding DeadzoneHeading, StringFormat='{}{0:F2}'}"
                                     FontSize="20" FontWeight="Bold" Width="110"
                                     TextAlignment="Center"
                                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                     BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                     BorderThickness="2" CornerRadius="8"
                                     Padding="8,6"/>
                            <TextBlock Text="deg"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Manual Turns -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="12" Padding="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Manual Turns"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Enable manual turn control"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding ManualTurnsEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Validation message -->
        <Border Grid.Row="3"
                Background="#C0392B"
                CornerRadius="8"
                Padding="12"
                Margin="0,16,0,0"
                IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
