<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:steer="clr-namespace:AgValoniaGPS.ViewModels.Wizards.SteerWizard;assembly=AgValoniaGPS.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="650"
             x:Class="AgValoniaGPS.Views.Controls.Wizards.SteerWizard.CpdCircleTestStepView"
             x:DataType="steer:CpdCircleTestStepViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                   Margin="0,0,0,12"/>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   FontSize="16"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Margin="0,0,0,24"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">

                <!-- Prerequisites: GPS + Speed -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Prerequisites"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

                        <!-- GPS Status: show the live FixQualityLabel so the operator can
                             see *why* recording is blocked (e.g. "RTK Float" vs. "No Fix"). -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Ellipse Grid.Column="0" Width="12" Height="12"
                                     VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{DynamicResource SystemAccentColor}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="GPS: " FontSize="14"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"/>
                                <TextBlock Text="{Binding FixQualityLabel}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                           IsVisible="{Binding IsRtkFixed}"/>
                                <TextBlock Text="{Binding FixQualityLabel}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           IsVisible="{Binding !IsRtkFixed}"/>
                                <TextBlock Text=" (RTK Fixed required)" FontSize="13"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           IsVisible="{Binding !IsRtkFixed}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Speed: highlight when within the ~5 km/h sweet spot. -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Ellipse Grid.Column="0" Width="12" Height="12"
                                     VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{DynamicResource SystemAccentColor}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}">
                                    <Run Text="Speed: "/><Run Text="{Binding Speed, StringFormat='{}{0:F1}'}"/><Run Text=" km/h"/>
                                </TextBlock>
                                <TextBlock Text=" (aim for ~5 km/h)" FontSize="13"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           IsVisible="{Binding !IsAtRecommendedSpeed}"/>
                                <TextBlock Text=" OK" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                           IsVisible="{Binding IsAtRecommendedSpeed}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Live steer angle -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="Live Steer Angle"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LiveSteerAngle, StringFormat='{}{0:F1}'}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Record / Stop buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                    <Button Command="{Binding StartRecordingCommand}"
                            Width="160" Height="52"
                            Background="{DynamicResource SystemControlHighlightAccentBrush}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                            CornerRadius="8"
                            HorizontalContentAlignment="Center"
                            IsVisible="{Binding !IsRecording}"
                            IsEnabled="{Binding CanRecord}">
                        <TextBlock Text="Record" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding StopRecordingCommand}"
                            Width="160" Height="52"
                            Background="#C0392B"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                            CornerRadius="8"
                            HorizontalContentAlignment="Center"
                            IsVisible="{Binding IsRecording}">
                        <TextBlock Text="Stop" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Recording status -->
                <TextBlock Text="Recording... drive in a steady circle"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding IsRecording}"/>

                <!-- Results section -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16"
                        IsVisible="{Binding TestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Results"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="{Binding TestResult}"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- Diameter display -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Measured Diameter"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Diameter, StringFormat='{}{0:F1} m'}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Calculated angle display -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Calculated Steer Angle"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CalculatedSteerAngle, StringFormat='{}{0:F1} deg'}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Manual CPD entry with slider -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="24,16">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Counts Per Degree"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding CountsPerDegree, StringFormat='{}{0:F0}'}"
                                     FontSize="20" FontWeight="Bold"
                                     Width="110"
                                     TextAlignment="Center"
                                     Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                     BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                                     BorderThickness="2" CornerRadius="8"
                                     Padding="8,6"/>
                        </Grid>
                        <Slider Minimum="1" Maximum="255"
                                Value="{Binding CountsPerDegree}"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Grid.Column="0" Text="1"
                                       FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBlock Grid.Column="1" Text="255"
                                       FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Validation message -->
        <Border Grid.Row="3"
                Background="#C0392B"
                CornerRadius="8"
                Padding="12"
                Margin="0,16,0,0"
                IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
