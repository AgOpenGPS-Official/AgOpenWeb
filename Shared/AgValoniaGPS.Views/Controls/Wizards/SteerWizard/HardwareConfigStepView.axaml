<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:steer="clr-namespace:AgValoniaGPS.ViewModels.Wizards.SteerWizard;assembly=AgValoniaGPS.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="700"
             x:Class="AgValoniaGPS.Views.Controls.Wizards.SteerWizard.HardwareConfigStepView"
             x:DataType="steer:HardwareConfigStepViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                   Margin="0,0,0,12"/>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   FontSize="16"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Margin="0,0,0,16"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- Steer Enable Method -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Steer Enable Method"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding SelectNone}"
                                    Classes="hw-option"
                                    Classes.selected="{Binding IsNoneSelected}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="None" FontSize="14" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="No external enable - autosteer always available"
                                               FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectSwitch}"
                                    Classes="hw-option"
                                    Classes.selected="{Binding IsSwitchSelected}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Switch" FontSize="14" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Toggle switch enables/disables"
                                               FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectButton}"
                                    Classes="hw-option"
                                    Classes.selected="{Binding IsButtonSelected}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Button" FontSize="14" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Momentary button to engage"
                                               FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Motor Driver -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Motor Driver"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Cytron"
                                    Command="{Binding SelectCytron}"
                                    Classes="hw-option"
                                    Classes.selected="{Binding IsCytronSelected}"
                                    Width="130"/>
                            <Button Content="IBT2"
                                    Command="{Binding SelectIBT2}"
                                    Classes="hw-option"
                                    Classes.selected="{Binding IsIBT2Selected}"
                                    Width="130"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- A/D Converter -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="A/D Converter"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Single"
                                    Command="{Binding SelectSingle}"
                                    Classes="hw-option"
                                    Classes.selected="{Binding IsSingleSelected}"
                                    Width="130"/>
                            <Button Content="Differential"
                                    Command="{Binding SelectDifferential}"
                                    Classes="hw-option"
                                    Classes.selected="{Binding IsDifferentialSelected}"
                                    Width="130"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Inversions -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Signal Inversions"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <!-- Invert Steer Enable Relay -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Image Grid.Column="0"
                                   Source="avares://AgValoniaGPS.Views/Assets/Icons/ConSt_InvertRelay.png"
                                   Width="32" Height="32" Stretch="Uniform"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Invert Steer Enable Relay"
                                           FontSize="14"
                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                <TextBlock Text="Inverts the relay that enables/disables the steering motor"
                                           FontSize="12"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          IsChecked="{Binding InvertRelays}"
                                          OnContent="ON" OffContent="OFF"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Danfoss -->
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="12" Padding="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Danfoss Valve"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBlock Text="Enable for Danfoss hydraulic steering"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding DanfossEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Validation message -->
        <Border Grid.Row="3"
                Background="#C0392B"
                CornerRadius="8"
                Padding="12"
                Margin="0,16,0,0"
                IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.hw-option">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.hw-option:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>
        <Style Selector="Button.hw-option.selected">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.hw-option.selected TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.hw-option.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        </Style>
    </UserControl.Styles>
</UserControl>
