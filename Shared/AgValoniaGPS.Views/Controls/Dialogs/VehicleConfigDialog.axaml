Vehicle configuration dialog (one half of the former monolithic
ConfigurationDialog). A chained sub-dialog of the Vehicle/Tool picker: opened
via "Configure Vehicle", Back returns to the picker, Close dismisses the chain.
Tabs: Vehicle (type / dimensions / antenna) and GPS Data Sources. Shares
ConfigurationViewModel + ConfigInputOverlays with the Tool dialog.
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:AgValoniaGPS.Views.Localization;assembly=AgValoniaGPS.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AgValoniaGPS.ViewModels;assembly=AgValoniaGPS.ViewModels"
             xmlns:conv="clr-namespace:AgValoniaGPS.Views.Converters;assembly=AgValoniaGPS.Views"
             xmlns:controls="clr-namespace:AgValoniaGPS.Views.Controls;assembly=AgValoniaGPS.Views"
             xmlns:config="clr-namespace:AgValoniaGPS.Views.Controls.Dialogs.Configuration;assembly=AgValoniaGPS.Views"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="750"
             x:Class="AgValoniaGPS.Views.Controls.Dialogs.VehicleConfigDialog"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding State.UI.IsVehicleConfigDialogVisible}"
             IsHitTestVisible="{Binding State.UI.IsVehicleConfigDialogVisible}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AgValoniaGPS.Views/Controls/Dialogs/Configuration/ConfigIcons.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Main TabControl styling for left icon strip -->
        <Style Selector="TabControl.MainConfigTabs">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabControl.MainConfigTabs > TabItem">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="MinHeight" Value="64"/>
        </Style>
        <Style Selector="TabControl.MainConfigTabs > TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        </Style>
        <Style Selector="TabControl.MainConfigTabs > TabItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Border Background="Transparent" PointerPressed="Backdrop_PointerPressed"/>

        <controls:DialogChrome Title="{loc:Localize VehicleConfiguration}"
                BackCommand="{Binding NavBackCommand}"
                CloseCommand="{Binding NavCloseChainCommand}"
                MinWidth="900" MaxWidth="980" MinHeight="620" MaxHeight="820">
            <Grid RowDefinitions="*,Auto"
                  DataContext="{Binding ConfigurationViewModel}">
                <!-- Main content area with TabControl + shared input overlays -->
                <Panel Grid.Row="0">
                    <TabControl Classes="MainConfigTabs" TabStripPlacement="Left" Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <!-- Vehicle Tab -->
                        <TabItem ToolTip.Tip="Vehicle">
                            <TabItem.Header>
                                <Border Width="40" Height="40" Background="{DynamicResource IconVehicle}"/>
                            </TabItem.Header>
                            <config:VehicleConfigTab/>
                        </TabItem>

                        <!-- Data Sources Tab -->
                        <TabItem ToolTip.Tip="Data Sources">
                            <TabItem.Header>
                                <Border Width="40" Height="40" Background="{DynamicResource IconSources}"/>
                            </TabItem.Header>
                            <config:SourcesConfigTab/>
                        </TabItem>
                    </TabControl>

                    <config:ConfigInputOverlays ZIndex="100"/>
                </Panel>

                <!-- Footer with profile info -->
                <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="16,12" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="{Binding Config.ActiveVehicleProfileName, StringFormat='Vehicle: {0}'}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontWeight="Bold" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{loc:Localize Units}" Foreground="{DynamicResource SystemControlForegroundBaseLowBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Config.IsMetric, Converter={x:Static conv:BoolToStringConverter.Instance}, ConverterParameter='Metric|Imperial'}"
                                       Foreground="#4A9" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </controls:DialogChrome>
    </Grid>
</UserControl>
