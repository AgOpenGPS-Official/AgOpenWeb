<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:AgValoniaGPS.Views.Localization;assembly=AgValoniaGPS.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AgValoniaGPS.ViewModels"
             xmlns:models="using:AgValoniaGPS.Models"
             xmlns:local="using:AgValoniaGPS.Views.Controls.Dialogs"
             mc:Ignorable="d"
             x:Class="AgValoniaGPS.Views.Controls.Dialogs.FlagListDialogPanel"
             x:Name="FlagListRoot"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding State.UI.IsFlagListDialogVisible}"
             IsHitTestVisible="{Binding State.UI.IsFlagListDialogVisible}">

    <Grid>
        <!-- Semi-transparent backdrop -->
        <Border Background="{DynamicResource ModalBackdropBrush}" PointerPressed="Backdrop_PointerPressed"/>

        <!-- Dialog panel -->
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16"
                MaxWidth="520" MaxHeight="520"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="{loc:Localize Flags}" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <Separator Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                </StackPanel>

                <!-- Flag list -->
                <ScrollViewer Grid.Row="1" MaxHeight="380">
                    <ItemsControl x:Name="FlagItems" ItemsSource="{Binding Flags}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Flag">
                                <Border Margin="0,2" Padding="8,6" CornerRadius="4"
                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                    <StackPanel Spacing="4">
                                        <!-- Main row -->
                                        <Grid ColumnDefinitions="28,*,Auto,Auto,28">
                                            <!-- Color indicator (tap to show color selector) -->
                                            <Button Grid.Column="0" Width="22" Height="22" Padding="0"
                                                    CornerRadius="11" BorderThickness="1"
                                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                    Click="ColorButton_Click" Tag="{Binding}"
                                                    ToolTip.Tip="Change color">
                                                <Button.Background>
                                                    <SolidColorBrush Color="{Binding FlagColor, Converter={x:Static local:FlagColorToBrushConverter.Instance}}"/>
                                                </Button.Background>
                                            </Button>

                                            <!-- Name (tap to edit) -->
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       Margin="8,0" FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                       PointerPressed="FlagName_PointerPressed"
                                                       Tag="{Binding}" Cursor="Hand"
                                                       FontWeight="Bold"/>

                                            <!-- Distance + direction from vehicle -->
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="6,0"
                                                       FontSize="11" HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Text="{Binding ., Converter={x:Static local:FlagDistanceConverter.Instance}}"/>

                                            <!-- Position -->
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="4,0"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                       Text="{Binding Easting, StringFormat='E:{0:F0}'}"/>

                                            <!-- Delete button -->
                                            <Button Grid.Column="4" Content="X" Width="22" Height="22"
                                                    Padding="0" FontSize="11" CornerRadius="4"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                    Click="DeleteFlag_Click" Tag="{Binding}"/>
                                        </Grid>

                                        <!-- Color selector (hidden by default, shown on tap) -->
                                        <WrapPanel x:Name="ColorSelector" IsVisible="False"
                                                   Margin="28,4,0,0" Tag="{Binding}">
                                            <!-- 10 color buttons generated in code-behind -->
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Name edit overlay (shown when editing a flag name) -->
                <Border x:Name="NameEditOverlay" Grid.RowSpan="3" IsVisible="False"
                        Background="#C0000000" CornerRadius="8">
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16"
                            MaxWidth="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Localize RenameFlag}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <TextBox x:Name="NameEditBox" FontSize="14" Watermark="Enter flag name"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="{loc:Localize OK}" Padding="16,6" Click="NameEditOK_Click"/>
                                <Button Content="{loc:Localize Cancel}" Padding="16,6" Click="NameEditCancel_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Footer buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="{loc:Localize PlaceFlagHere}" Padding="12,6"
                            Command="{Binding PlaceFlagHereCommand}"/>
                    <Button Content="{loc:Localize PlaceOnMap}" Padding="12,6"
                            Command="{Binding PlaceFlagOnClickCommand}"/>
                    <Button Content="{loc:Localize DeleteAll}" Padding="12,6"
                            Command="{Binding DeleteAllFlagsCommand}"/>
                    <Button Content="{loc:Localize Close}" Padding="12,6"
                            Command="{Binding CloseFlagListCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
