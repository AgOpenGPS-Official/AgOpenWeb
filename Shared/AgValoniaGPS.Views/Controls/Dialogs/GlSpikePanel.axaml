<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AgValoniaGPS.ViewModels"
             xmlns:c="using:AgValoniaGPS.Views.Controls"
             x:Class="AgValoniaGPS.Views.Controls.Dialogs.GlSpikePanel"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding State.UI.IsGlSpikeDialogVisible}"
             IsHitTestVisible="{Binding State.UI.IsGlSpikeDialogVisible}">

    <Border Background="#C0000000">
        <Border Background="#1E1E1E"
                BorderBrush="#404040" BorderThickness="1"
                CornerRadius="6"
                Margin="20">
            <Grid RowDefinitions="Auto * Auto">
                <Grid Grid.Row="0" ColumnDefinitions="* Auto" Background="#252525" Height="44">
                    <TextBlock Grid.Column="0" Text="GL Spike (Silk.NET + OpenGL ES)"
                               VerticalAlignment="Center" Margin="12,0"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="Close" Width="100" Height="36"
                            Margin="4" VerticalAlignment="Center"
                            Command="{Binding CloseGlSpikeCommand}"/>
                </Grid>

                <c:GlSpikeControl Grid.Row="1"/>

                <TextBlock Grid.Row="2" Margin="12,6" Foreground="#A0A0A0" FontSize="12"
                           Text="Green ground + yellow boundary rectangle + red vehicle cross under tilted perspective = GL path works on this platform."/>
            </Grid>
        </Border>
    </Border>
</UserControl>
