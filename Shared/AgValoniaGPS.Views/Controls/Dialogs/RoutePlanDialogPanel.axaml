<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AgValoniaGPS.ViewModels;assembly=AgValoniaGPS.ViewModels"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="500"
             x:Class="AgValoniaGPS.Views.Controls.Dialogs.RoutePlanDialogPanel"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding State.UI.IsRoutePlanDialogVisible}"
             IsHitTestVisible="{Binding State.UI.IsRoutePlanDialogVisible}">

    <!-- Non-modal floating panel — positioned bottom-right, no backdrop -->
    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            CornerRadius="12" Padding="0" Opacity="0.95"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,16,80" Width="320">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto">
            <!-- Header — drag handle + close button -->
            <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="12,12,0,0" Padding="12,8" Cursor="Hand"
                    PointerPressed="Header_PointerPressed"
                    PointerMoved="Header_PointerMoved"
                    PointerReleased="Header_PointerReleased">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Route Plan" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                               IsHitTestVisible="False"/>
                    <Button Grid.Column="1" Content="X" FontSize="12" FontWeight="Bold"
                            Width="28" Height="28" Padding="0"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            CornerRadius="14"
                            Command="{Binding CloseRoutePlanDialogCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </Grid>
            </Border>

            <!-- Pattern + Track Count -->
            <StackPanel Grid.Row="1" Spacing="8" Margin="12,8">
                <!-- Pattern -->
                <Grid ColumnDefinitions="Auto,*,*">
                    <TextBlock Grid.Column="0" Text="Pattern:" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                               Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Sequential" Margin="2" Height="30" FontSize="11"
                            HorizontalContentAlignment="Center" CornerRadius="6"
                            Command="{Binding SetRoutePlanPatternCommand}" CommandParameter="Boustrophedon"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <Button Grid.Column="2" Content="Snake" Margin="2" Height="30" FontSize="11"
                            HorizontalContentAlignment="Center" CornerRadius="6"
                            Command="{Binding SetRoutePlanPatternCommand}" CommandParameter="Snake"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </Grid>

                <!-- Track Count -->
                <Grid ColumnDefinitions="*,*,*,*">
                    <Button Grid.Column="0" Content="5" Margin="2" Height="30" FontSize="11"
                            HorizontalContentAlignment="Center" CornerRadius="6"
                            Command="{Binding SetRoutePlanCountCommand}" CommandParameter="5"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <Button Grid.Column="1" Content="10" Margin="2" Height="30" FontSize="11"
                            HorizontalContentAlignment="Center" CornerRadius="6"
                            Command="{Binding SetRoutePlanCountCommand}" CommandParameter="10"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <Button Grid.Column="2" Content="20" Margin="2" Height="30" FontSize="11"
                            HorizontalContentAlignment="Center" CornerRadius="6"
                            Command="{Binding SetRoutePlanCountCommand}" CommandParameter="20"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <Button Grid.Column="3" Content="All" Margin="2" Height="30" FontSize="11"
                            HorizontalContentAlignment="Center" CornerRadius="6"
                            Command="{Binding SetRoutePlanCountCommand}" CommandParameter="0"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </Grid>

                <!-- Status -->
                <TextBlock Text="{Binding RoutePlanStatus}" FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Action Buttons -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" Margin="12,4,12,8">
                <Button Grid.Column="0" Content="Start" Margin="2" Height="34" FontSize="13" FontWeight="Bold"
                        HorizontalContentAlignment="Center" CornerRadius="6"
                        Command="{Binding StartRouteCommand}"
                        IsVisible="{Binding !IsRouteActive}"
                        Background="#2E7D32" Foreground="White"/>
                <Button Grid.Column="0" Content="Stop" Margin="2" Height="34" FontSize="13" FontWeight="Bold"
                        HorizontalContentAlignment="Center" CornerRadius="6"
                        Command="{Binding StopRouteCommand}"
                        IsVisible="{Binding IsRouteActive}"
                        Background="#C62828" Foreground="White"/>
                <Button Grid.Column="1" Content="Skip" Margin="2" Height="34" FontSize="13" FontWeight="Bold"
                        HorizontalContentAlignment="Center" CornerRadius="6"
                        Command="{Binding SkipSegmentCommand}"
                        IsVisible="{Binding IsRouteActive}"
                        Background="#F57F17" Foreground="White"/>
                <Button Grid.Column="1" Content="Clear" Margin="2" Height="34" FontSize="13" FontWeight="Bold"
                        HorizontalContentAlignment="Center" CornerRadius="6"
                        Command="{Binding ClearPlannedSwathsCommand}"
                        IsVisible="{Binding !IsRouteActive}"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <Button Grid.Column="2" Content="Close" Margin="2" Height="34" FontSize="13" FontWeight="Bold"
                        HorizontalContentAlignment="Center" CornerRadius="6"
                        Command="{Binding CloseRoutePlanDialogCommand}"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
