<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AgValoniaGPS.ViewModels;assembly=AgValoniaGPS.ViewModels"
             xmlns:controls="clr-namespace:AgValoniaGPS.Views.Controls;assembly=AgValoniaGPS.Views"
             mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="550"
             x:Class="AgValoniaGPS.Views.Controls.Dialogs.Configuration.UTurnConfigTab"
             x:DataType="vm:ConfigurationViewModel">

    <UserControl.Styles>
        <!-- Parameter Card -->
        <Style Selector="Border.ParamCard">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <TextBlock Text="U-Turn Settings" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" Margin="16,12,16,8"/>

        <ScrollViewer Grid.Row="1">
            <!-- 3-Column Layout matching AgOpenGPS -->
            <Grid ColumnDefinitions="*,*,*" Margin="12,8,12,16">

                <!-- LEFT COLUMN: Extension Length -->
                <Border Grid.Column="0" Classes="ParamCard" Margin="4">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <!-- Graphic -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="6" Padding="8" Height="120">
                            <Image Source="avares://AgValoniaGPS.Views/Assets/Icons/Config/ConU_UturnLength.png" Stretch="Uniform"/>
                        </Border>

                        <!-- Value Display -->
                        <controls:EditableNumericField HorizontalAlignment="Center"
                            Value="{Binding Guidance.UTurnExtension, Mode=TwoWay}"
                            Unit="m" FormatString="F1"
                            EditCommand="{Binding EditUTurnExtensionCommand}"/>

                        <!-- Tip Text -->
                        <TextBlock Text="Set extension length to 2 or 3x Radius"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="11" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- MIDDLE COLUMN: Smoothing -->
                <Border Grid.Column="1" Classes="ParamCard" Margin="4">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <!-- Graphic -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="6" Padding="8" Height="120">
                            <Image Source="avares://AgValoniaGPS.Views/Assets/Icons/Config/ConU_UturnSmooth.png" Stretch="Uniform"/>
                        </Border>

                        <!-- Value Display -->
                        <controls:EditableNumericField HorizontalAlignment="Center"
                            Value="{Binding Guidance.UTurnSmoothing, Mode=TwoWay}"
                            Unit="" FormatString="F0"
                            EditCommand="{Binding EditUTurnSmoothingCommand}"/>

                        <!-- Tip Text -->
                        <TextBlock Text="Set Smoothing 3-4x Radius"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="11" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- RIGHT COLUMN: Turn Radius + Trigger Distance stacked -->
                <StackPanel Grid.Column="2" Spacing="8">
                    <!-- Turn Radius (Top) -->
                    <Border Classes="ParamCard" Margin="4">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <!-- Graphic -->
                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="6" Padding="8" Height="80">
                                <Image Source="avares://AgValoniaGPS.Views/Assets/Icons/Config/ConU_UturnRadius.png" Stretch="Uniform"/>
                            </Border>

                            <!-- Value Display -->
                            <controls:EditableNumericField HorizontalAlignment="Center"
                                Value="{Binding Guidance.UTurnRadius, Mode=TwoWay}"
                                Unit="m" FormatString="F2"
                                EditCommand="{Binding EditUTurnRadiusCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Trigger Distance (Bottom) -->
                    <Border Classes="ParamCard" Margin="4">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <!-- Graphic -->
                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="6" Padding="8" Height="80">
                                <Image Source="avares://AgValoniaGPS.Views/Assets/Icons/Config/ConU_UturnDistance.png" Stretch="Uniform"/>
                            </Border>

                            <!-- Value Display -->
                            <controls:EditableNumericField HorizontalAlignment="Center"
                                Value="{Binding Guidance.UTurnDistanceFromBoundary, Mode=TwoWay}"
                                Unit="m" FormatString="F2"
                                EditCommand="{Binding EditUTurnDistanceCommand}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
